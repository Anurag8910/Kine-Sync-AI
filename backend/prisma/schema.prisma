generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  profile   Profile?
  metrics   Metrics?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dailyLogs     DailyLog[]
  trainingLogs  TrainingLog[]
  sleepLogs     SleepLog[]
  waterLogs     WaterLog[]
  weightLogs    WeightLog[]
  bfpLogs       BfpLog[]
  exerciseLogs  ExerciseLog[]
}

model Profile {
  id        Int    @id @default(autoincrement())
  user      User   @relation(fields: [userId], references: [id])
  userId    Int    @unique
  age       Int?
  gender    String?
  heightCm  Float?
  currentWeightKg Float?
  mainGoal  String?
  activityLevel String?
}

model Metrics {
  id        Int    @id @default(autoincrement())
  user      User   @relation(fields: [userId], references: [id])
  userId    Int    @unique
  targetCalories Int?
  BMR       Float?
  targetSleepHours Int? @default(8)
  targetGlasses Int? @default(8)
}

model DailyLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  carbs     Int
  protein   Int
  fat       Int
  date      DateTime
}

model TrainingLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  durationMinutes Int
  date      DateTime
}

model SleepLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  durationHours Float
  date      DateTime
}

model WaterLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  glasses   Int
  date      DateTime
}

model WeightLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  weight    Float
  date      DateTime
}

model BfpLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  bfp       Float
  date      DateTime
}

model ExerciseLog {
  id            Int      @id @default(autoincrement())
  user          User     @relation(fields: [userId], references: [id])
  userId        Int
  exerciseType  String   // e.g., 'squats', 'pushups', 'plank'
  duration      Int      // duration in seconds
  reps          Int?     // optional rep count
  date          DateTime @default(now())
}
